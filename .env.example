# Copy this file to .env and fill in your values for local development.
# Never commit .env to version control.

# eBay Developer App credentials
# Get these from https://developer.ebay.com/my/keys
EBAY_APP_ID=your-ebay-app-id-here
EBAY_CERT_ID=your-ebay-cert-id-here

# Google Sheets service account JSON, base64-encoded
# See README for how to create and encode this
GOOGLE_SHEETS_CREDENTIALS=base64-encoded-service-account-json

# WhatsApp via CallMeBot
# Phone in international format without +, e.g. 61412345678
WHATSAPP_PHONE=61412345678
# API key from CallMeBot setup (see README)
CALLMEBOT_API_KEY=your-callmebot-api-key
